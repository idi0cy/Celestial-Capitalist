	onButton()

func _on_loot_refresh_refresh(theValue: Variant) -> void:
	if theValue == 0.0:
		genLootables()

func _on_timer_end_game() -> void:
	drawn.drawingOn = false
	drawn.reset()
	timer.value = 0
	minigameWindow.hide()
	lootTurnout.show()
	if (drawn.score < 0):
		drawn.score = 0
	reference.pixelCount = reference.pixelCount / 2
	terminalText.targetText = "> System: You scored " + str(drawn.score) + "/" + str(reference.pixelCount) + "\n Select loot to keep. Exit menu at any time to discard undesired items."
	terminalText.fillText()
	itemDesc.itemSelected = false
	lootTurnout.show()
	genLoot()
	drawn.score = 0
	drawn.drawnPixels = []
	reference.pixelCount = 0
	reference.reset()
	
func takeLoot(item, listIndex, itemQ, itemName):
	if ((listIndex <= lootBox.get_child_count() - 1)):
		if (lootBox.get_child(listIndex) != null):
			var obj = lootBox.get_child(listIndex)
			inventory.addItem(item, itemQ, itemName)
			lootBox.remove_child(obj)
			obj.queue_free()
			if (lootBox.get_child_count() == 0):
				reset()
				scavengeOpen = false

func genLoot():
	var currentLootable = allLootables[storedLootable]
	for item in lootBox.get_children():
		lootBox.remove_child(item)
		item.queue_free()
	
	if takeButton.pressed.is_connected(takeLoot):
		takeButton.pressed.disconnect(self.takeLoot)
	takeButtonContainer.hide()
	
	if currentLootable[2] > 1 and currentLootable[2] <= 2:
		lootCount = randi_range(1,2)
	elif currentLootable[2] > 2 and currentLootable[2] <= 3:
		lootCount = randi_range(2,3)
	elif currentLootable[2] > 3 and currentLootable[2] <= 4:
		lootCount = randi_range(3,4)
	elif currentLootable[2] > 4 and currentLootable[2] <= 5:
		lootCount = randi_range(4,5)
	else:
		lootCount = 0

	var tempLootTable = currentLootable[5].duplicate_deep()
	var temporaryList = []
	for item in tempLootTable:
		temporaryList.append(item)
	
	var generatedIndex = 0
	
	#generate roll based on a bell curve from 0 to largest weight value in loot table, with standard deviation largest weight / 1.25
	var roll = randfn(tempLootTable.values().max(), tempLootTable.values().max()/1.25)
	# set any generated roll above max weight to max weight - prevents out of bounds index errors
	# aka i was too lazy to make a curve resource myself so i just cannibalized and butchered a bell curve in half
	# negative roll values are fine - this just means all items in the pool are possible and they should be rare
	if (roll > tempLootTable.values().max()):
		roll = tempLootTable.values().max()
	var tempLootTableResults = []
	# if weight of item is higher than roll, add to an array
	for item in tempLootTable:
		if roll <= tempLootTable[item] && generatedIndex < currentLootable[2]:
			tempLootTableResults.append(item)
	for i in currentLootable[2]:
			#pick random item with even chances from said array, add to loot results
			var finalItem = tempLootTableResults.pick_random()
			
			var scorePercentage = snapped((drawn.score / reference.pixelCount), 0.01)
			# percentage scored * lootable tier * 25, rounded to the nearest whole
			var qualityPreDeviation = snapped((allLootables[storedLootable][1] * scorePercentage), 1)
			# add deviation to quality - larger deviation range to lower qualities
			var itemQual = randi_range(qualityPreDeviation - 15, qualityPreDeviation + 5)
			# no negative qualities
			if (itemQual <= 0):
				itemQual = 1
			var itemVal = finalItem[2]
			var displayName = prefixes.pick_random() + " " + finalItem[0]
			
			var takeableLootButton = TextureButton.new()
			takeableLootButton.texture_normal = finalItem[-1]
			takeableLootButton.name = finalItem[0]
			takeableLootButton.set_script(load("res://Scripts/RockBottom/takeableLootButton.gd"))
			takeableLootButton.baseInfo = finalItem
			takeableLootButton.index = generatedIndex
			takeableLootButton.pressed.connect(identifyLoot.bind(finalItem, takeableLootButton, displayName, itemQual, itemVal))
			
			lootBox.add_child(takeableLootButton)
			lootBox.get_child(takeableLootButton.get_index()).name = finalItem[0]
			generatedIndex += 1

func identifyLoot(item, selectedLoot, displayName, itemQual, itemVal):
	terminalText.hide()
	flavourText.text = item[5]
	itemIcon.texture = item[-1]
	Item.text = displayName
	itemQuality.icon = inventory.getStars(itemQual)
	itemQuality.text = str(itemQual) + "/100"
	itemValue.text = str(snapped(itemQual * itemVal * 0.01, 0.01))
	itemDesc.itemSelected = true
	if takeButton.pressed.is_connected(takeLoot):
		takeButton.pressed.disconnect(self.takeLoot)
	if (selectedLoot.get_index() != null):
		takeButton.pressed.connect(takeLoot.bind(item, selectedLoot.get_index(), itemQual, displayName))
	takeButtonContainer.show()

