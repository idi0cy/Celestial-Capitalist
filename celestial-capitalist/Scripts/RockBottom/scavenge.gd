func newLootable(
	lootableName:String, lootQuality:float, containerSize:int,
	difficulty:float, texture:Texture2D, lootTable:Dictionary):
	var lootable = [lootableName, lootQuality, containerSize, difficulty, texture, lootTable]
	allLootables.append(lootable)
	return lootable

func _ready():
	lootTurnout.hide()
	reset()
	for item in lootableList.get_children():
		lootableList.remove_child(item)
		item.queue_free()
	for item in lootBox.get_children():
		lootBox.remove_child(item)
		item.queue_free()
	genLootables()

func genLootables():
	for item in lootableList.get_children():
		lootableList.remove_child(item)
		item.queue_free()
	
	if lootButton.pressed.is_connected(loot):
		lootButton.pressed.disconnect(self.loot)
	lootButtonContainer.hide()
	lootableDesc.targetText = ""
	lootableDesc.fillText()
	
	var temporaryList = []
	for item in allLootables:
		temporaryList.append(item)
	
	#pick how many lootables based on money count - higher money less lootables
	if ledger.money >= 0 and ledger.money <= 10:
		lootableCount = 4
	elif ledger.money > 10 and ledger.money <= 100:
		lootableCount = randi_range(3,4)
	elif ledger.money > 100 and ledger.money <= 300:
		lootableCount = randi_range(2,3)
	elif ledger.money > 300 and ledger.money <= 700:
		lootableCount = randi_range(1,2)
	else:
		lootableCount = 1

	var generatedIndex = 0
	for i in lootableCount:
		#pick lootables available via money, higher money = higher level lootables
		var randomRegistryIndex:int
		if ledger.money >= 0 and ledger.money <= 10:
			lootableCount = randi_range(4,5)
			randomRegistryIndex = randi_range(0, (len(temporaryList) - 4))
		elif ledger.money > 10 and ledger.money <= 100:
			lootableCount = randi_range(3,4)
			randomRegistryIndex = randi_range(0, (len(temporaryList) - 3))
		elif ledger.money > 100 and ledger.money <= 300:
			lootableCount = randi_range(2,3)
			randomRegistryIndex = randi_range(0, (len(temporaryList) - 2))
		elif ledger.money > 300 and ledger.money <= 700:
			lootableCount = randi_range(1,2)
			randomRegistryIndex = randi_range(0, (len(temporaryList) - 1))
		else:
			lootableCount = 1
			randomRegistryIndex = randi_range(0, (len(temporaryList) - 4))

		lootableButton = TextureButton.new()
		lootableButton.texture_normal = allLootables[randomRegistryIndex][4]
		lootableButton.name = allLootables[randomRegistryIndex][0]
		lootableButton.set_script(load("res://Scripts/RockBottom/lootableButton.gd"))
		lootableButton.baseInfo = allLootables[randomRegistryIndex]
		lootableButton.index = generatedIndex
		lootableButton.pressed.connect(identifyTarget.bind(randomRegistryIndex, generatedIndex, allLootables[randomRegistryIndex][0]))
		lootableList.add_child(lootableButton)
		lootableList.get_child(generatedIndex).name = allLootables[randomRegistryIndex][0]
		generatedIndex += 1

func identifyTarget(registryIndex, listIndex, displayName):
	lootableDesc.targetText = displayName
	lootableDesc.fillText()
	#haggle.storedStrangerIndex = place
	if lootButton.pressed.is_connected(loot):
		lootButton.pressed.disconnect(self.loot)
	lootButton.pressed.connect(loot.bind(registryIndex, listIndex))
	lootButtonContainer.show()

func removeLootable(listIndex):
	count = 0
	for obj in lootableList.get_children():
		if count == listIndex:
			lootableList.remove_child(obj)
			obj.queue_free()
		count += 1

#registryIndex refers to allLootables, listIndex refers to the lootableList node
func loot(registryIndex, listIndex):
	curSelPlace = listIndex
	directive.hide()
	$pickLootable/lootableDesc.hide()
	lootButtonContainer.hide()
	lootResult.show()
	lootTurnout.hide()
	$lootResult/Terminal.show()
	lootableList.lootableListHidden = true
	minigameWindow.show()
	terminalText.show()
	terminalText.targetText = "> System: Cut into the lootable as accurately as possible over the guideline. Cutting outside the lines will damage loot inside."
	terminalText.fillText()
	reference.reset()
	drawn.reset()
	drawn.score = 0
	reference.texture = referenceTextures[allLootables[registryIndex][3]]
	reference.writePixelsToArray()
	reference.countPixels()
	drawn.drawnPixels = []
	drawn.drawingOn = true
	timer.difficultyIndex = allLootables[registryIndex][3]
	storedLootable = registryIndex
	timer.startTimer()
	

func reset():
	curSelPlace = "None"
	refreshExplanation.targetText = ""
	refreshExplanation.fillText()
	if lootButton.pressed.is_connected(loot):
		lootButton.pressed.disconnect(self.loot)
	directive.show()
	lootableDesc.show()
	lootableDesc.text = ""
	terminalText.targetText = ""
	terminalText.fillText()
	terminal.hide()
	lootButtonContainer.hide()
	lootResult.hide()
	lootTurnout.hide()
	reference.reset()
	drawn.reset()
	drawn.score = 0
	drawn.drawnPixels = []
	drawn.drawingOn = true
	$pickLootable.show()

func onButton():
	lootResult.hide()
	terminalText.targetText = ""
	terminalText.fillText()
	reset()
	scavengeOpen = not scavengeOpen
	if scavengeOpen == true:
		lootableList.lootableListHidden = false
		lootableDesc.text = ""
		lootableDesc.show()
		directive.targetText = "Lootables Identified"
		directive.fillText()
		refreshExplanation.targetText = "Until new lootables"
		refreshExplanation.fillText()
		directive.show()

func _process(_delta):
	if scavengeOpen == false:
		self.hide()
	else:
		self.show()

