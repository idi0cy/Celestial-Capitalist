var productQualities = [25, 50, 75, 100]

func newStall(
	stallName:String, ownerName:String,
	ownerPortrait, lootTable:Dictionary):
	var stall = [stallName, ownerName, ownerPortrait, lootTable]
	allStalls.append(stall)
	return stall

func _ready():
	genStall()

func genStall():
	for item in productList.get_children():
		productList.remove_child(item)
		item.queue_free()
	currentStall = allStalls.pick_random()
	if !uniqueStalls.has(currentStall[0]):
		currentStall[0] = prefixes.pick_random() + " " + currentStall[0] + " " + suffixes.pick_random()
	if currentStall[1] == "random":
		currentStall[1] = genName(currentStall[0])
	ownerNameLabel.text = currentStall[1]
	if !(currentStall[2] is Texture2D):
		currentStall[2] = portraits.pick_random()
	ownerPortraitSprite.texture = currentStall[2]
	var productQualityIndex = randi_range(0, 3)
	productQuality = productQualities[productQualityIndex]
	genProducts()

func genName(inputSeed):
	var charList = []
	for character in inputSeed:
		charList.append(character)
	charList.shuffle()
	var generatedSeed = "".join(charList)
	var generator = RandomNumberGenerator.new()
	generator.seed = generatedSeed.hash()
	var firstName = generator.randi_range(0,len(dialogueLib.names)-1)
	var surname = generator.randi_range(0,len(dialogueLib.names)-1)
	return dialogueLib.names[firstName] + " " + dialogueLib.names[surname]

func genProducts():
	for item in productList.get_children():
		productList.remove_child(item)
		item.queue_free()
	
	if buyButton.pressed.is_connected(buy):
		buyButton.pressed.disconnect(self.buy)
	buyButtonContainer.hide()
		
	var tempLootTable = currentStall[3].duplicate_deep()
	var temporaryList = []
	for item in tempLootTable:
		temporaryList.append(item)
	
	var generatedIndex = 0
	
	#generate roll based on a bell curve from 0 to largest weight value in loot table, with standard deviation largest weight / 1.25
	var roll = randfn(tempLootTable.values().max(), tempLootTable.values().max()/1.25)
	# set any generated roll above max weight to max weight - prevents out of bounds index errors
	# aka i was too lazy to make a curve resource myself so i just cannibalized and butchered a bell curve in half
	# negative roll values are fine - this just means all items in the pool are possible and they should be rare
	if (roll > tempLootTable.values().max()):
		roll = tempLootTable.values().max()
	var tempLootTableResults = []
	# if weight of item is higher than roll, add to an array
	for item in tempLootTable:
		if roll <= tempLootTable[item]:
			tempLootTableResults.append(item)
	for i in 4:
		#pick random item with even chances from said array, add to loot results
		var finalItem = tempLootTableResults.pick_random()
		# random percentage * random lootable tier, rounded to the nearest whole
		var qualityPreDeviation = snapped((productQuality * randf()), 1)
		# add deviation to quality - larger deviation range to lower qualities
		var itemQual = randi_range(qualityPreDeviation - 15, qualityPreDeviation + 5)
		# no negative qualities
		if (itemQual <= 0):
			itemQual = 1
		var itemVal = finalItem[2]
		var displayName = prefixes.pick_random() + " " + finalItem[0]
		
		productButton = TextureButton.new()
		productButton.texture_normal = finalItem[-1]
		productButton.name = finalItem[0]
		productButton.set_script(load("res://Scripts/RockBottom/productButton.gd"))
		productButton.baseInfo = finalItem
		productButton.index = generatedIndex
		productButton.pressed.connect(identifyProduct.bind(finalItem, productButton, displayName, itemQual, itemVal, finalItem[-1]))
		productList.add_child(productButton)
		productList.get_child(generatedIndex).name = finalItem[0]
		generatedIndex += 1

func identifyProduct(item, selectedProduct, displayName, itemQual, itemVal, itemTexture):
	flavourText.text = item[5]
	itemIcon.texture = item[-1]
	itemName.text = displayName
	itemQuality.icon = inventory.getStars(itemQual)
	itemQuality.text = str(itemQual) + "/100"
	var itemTrueValue = snapped(itemQual * itemVal * 0.01, 0.01)
	itemValue.text = str(itemTrueValue)
	itemDesc.itemSelected = true
	if buyButton.pressed.is_connected(buy):
		buyButton.pressed.disconnect(self.buy)
	if (selectedProduct.get_index() != null):
		buyButton.pressed.connect(buy.bind(item, selectedProduct.get_index(), itemQual, displayName, itemTrueValue, itemTexture))
	buyButtonContainer.show()

func removeProduct(listIndex):
	count = 0
	for obj in productList.get_children():
		if count == listIndex:
			productList.remove_child(obj)
			obj.queue_free()
		count += 1


func buy(item, listIndex, itemQual, itemDisplayName, itemTrueValue, itemTexture):
	if itemTrueValue < ledger.money:
		$pickProduct/itemDesc.hide()
		if ((listIndex <= productList.get_child_count() - 1)):
			if (productList.get_child(listIndex) != null):
				var obj = productList.get_child(listIndex)
				inventory.addItem(item, itemQual, itemDisplayName)
				ledger.money -= itemTrueValue
				ledger.addEntry(-itemTrueValue, clock.theTime, currentStall[0], itemDisplayName, itemTexture)
				productList.remove_child(obj)
				obj.queue_free()
				if (productList.get_child_count() == 0):
					marketOpen = false

func onButton():
	marketOpen = not marketOpen
	if marketOpen == true:
		productList.productListHidden = false
		itemName.text = ""
		itemName.show()
		buyButton.show()
		stallNameDisplay.targetText = currentStall[0]
		stallNameDisplay.fillText()
		stallNameDisplay.show()

func _process(_delta):
	if marketOpen == false:
		self.hide()
	else:
		self.show()
	if clock.theTime == 0:
		genStall()

